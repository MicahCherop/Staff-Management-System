{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users including staff and administrators",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "staff"] },
        "branch": { "type": "string" },
        "jobTitle": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "exited"] },
        "joinedAt": { "type": "string", "format": "date-time" },
        "exitDate": { "type": "string", "format": "date-time" },
        "exitedReason": { "type": "string" }
      },
      "required": ["uid", "displayName", "email", "role", "branch", "status"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily attendance records",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "description": "YYYY-MM-DD" },
        "status": { "type": "string", "enum": ["present", "absent", "leave"] },
        "timeIn": { "type": "string" },
        "timeOut": { "type": "string" },
        "branch": { "type": "string" }
      },
      "required": ["userId", "date", "status", "branch"]
    },
    "LeaveRequest": {
      "title": "Leave Request",
      "description": "Staff leave applications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "approvedBy": { "type": "string" },
        "branch": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "startDate", "endDate", "status", "branch"]
    },
    "Vacancy": {
      "title": "Vacancy",
      "description": "Job openings and recruitment",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "branch": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "postedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "branch", "status"]
    },
    "Placement": {
      "title": "Placement",
      "description": "Placement of candidates into vacancies",
      "type": "object",
      "properties": {
        "vacancyId": { "type": "string" },
        "candidateName": { "type": "string" },
        "status": { "type": "string", "enum": ["offered", "hired", "rejected"] },
        "placementDate": { "type": "string", "format": "date" },
        "branch": { "type": "string" }
      },
      "required": ["vacancyId", "candidateName", "status", "branch"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Daily attendance logs"
    },
    "/leaves/{leaveId}": {
      "schema": "LeaveRequest",
      "description": "Leave requests"
    },
    "/vacancies/{vacancyId}": {
      "schema": "Vacancy",
      "description": "Job vacancies"
    },
    "/placements/{placementId}": {
      "schema": "Placement",
      "description": "Job placements"
    }
  }
}
